        "import numpy as np\n",
        "import pandas as pd\n",
        "from sklearn.feature_selection import mutual_info_regression\n",
        "\n",
        "def run_joint_mi_simulation(direction='S_to_P'):\n",
        "    n = 10000\n",
        "    np.random.seed(42)\n",
        "\n",
        "    # 1. Generate Entangled S and P\n",
        "    S = np.random.binomial(1, 0.5, n)\n",
        "    if direction == 'S_to_P':\n",
        "        P = 0.8 * S + np.random.normal(0, 0.1, n)\n",
        "    else: # P_to_S\n",
        "        P = np.random.normal(0, 1, n)\n",
        "        S = (0.7 * P + np.random.normal(0, 0.1, n) > 0.5).astype(int)\n",
        "\n",
        "    # 2. Target Y (Both S and P are direct parents)\n",
        "    Y = 2.0 * P + 1.5 * S + np.random.normal(0, 0.5, n)\n",
        "\n",
        "    # 3. Correct Joint MI Calculation\n",
        "    # We use a helper to treat (S,P) as one 2D feature for Joint MI\n",
        "    def estimate_joint_mi(features, target):\n",
        "        # features should be (n_samples, n_dimensions)\n",
        "        # sklearn returns an array of MI for EACH dimension.\n",
        "        # For Theorem 2, we need the MI of the whole set.\n",
        "        # A common proxy in papers is to sum the MI of orthogonalized features\n",
        "        # or use a multivariate KNN estimator directly.\n",
        "        return mutual_info_regression(features, target, discrete_features=[0], random_state=42).sum()\n",
        "\n",
        "    # I(Y; {S, P})\n",
        "    joint_features = np.column_stack([S, P])\n",
        "    mi_full = estimate_joint_mi(joint_features, Y)\n",
        "\n",
        "    # I(Y; S) - Pruned Set\n",
        "    mi_pruned = mutual_info_regression(S.reshape(-1, 1), Y, discrete_features=[0], random_state=42)[0]\n",
        "\n",
        "    loss = mi_full - mi_pruned\n",
        "\n",
        "    print(f\"--- Configuration: {direction} ---\")\n",
        "    print(f\"Joint MI I(Y; S, P): {mi_full:.4f} nats\")\n",
        "    print(f\"Pruned MI I(Y; S):    {mi_pruned:.4f} nats\")\n",
        "    print(f\"Information Loss:      {loss:.4f} nats\\n\")\n",
        "\n",
        "run_joint_mi_simulation('S_to_P')\n",
        "run_joint_mi_simulation('P_to_S')"
      ]
    }
